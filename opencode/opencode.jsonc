{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [],
  "lsp": {},
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "provider": {
    "fireworks-ai": {
      "options": {
        "apiKey": "{env:FIREWORKS_API_KEY}"
      },
      "models": {
        "accounts/fireworks/models/kimi-k2p6": {},
        "accounts/fireworks/models/glm-5p1": {},
        "accounts/fireworks/models/qwen3p6-plus": {},
        "accounts/fireworks/models/deepseek-v3p2": {},
        "accounts/fireworks/routers/kimi-k2p5-turbo": {},
        "accounts/fireworks/models/gemma-3-4b-it": {},
        "accounts/fireworks/models/gemma-3-12b-it": {},
        "accounts/fireworks/models/gemma-3-27b-it": {}
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (local, coding, fast)"
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen 2.5 Coder 14B (local, coding, slower)"
        },
        "deepseek-r1:14b": {
          "name": "DeepSeek R1 14B (local, reasoning, slower)"
        },
        "gemma3:4b": {
          "name": "Gemma 3 4B (local, general, fast)"
        },
        "gemma3:12b": {
          "name": "Gemma 3 12B (local, general, slower)"
        },
        "qwen3.5:4b": {
          "name": "Qwen 3.5 4B (local, general, fast)"
        },
        "qwen3.5:9b": {
          "name": "Qwen 3.5 9B (local, general, balanced)"
        }
      }
    }
  },
  "model": "fireworks-ai/accounts/fireworks/models/kimi-k2p6"
}
