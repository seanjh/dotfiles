{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    "opencode-openai-codex-auth@4.1.1"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "environment": {"CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"}
    }
  }
}
